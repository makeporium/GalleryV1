<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pastel_bg_lavender"
    android:orientation="vertical">

    <!-- Top Bar with Activity/Messages Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:background="@color/pastel_surface_card">

        <LinearLayout
            android:layout_width="240dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_input_round"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/toggleActivity"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Activity"
                android:textColor="@color/pastel_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/toggleMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_button_purple"
                android:gravity="center"
                android:text="Messages"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="@color/pastel_surface_card"
        android:hint="Search conversations..."
        android:paddingHorizontal="12dp"
        android:textColor="@color/pastel_text_primary"
        android:textColorHint="@color/pastel_text_secondary"
        android:textSize="16sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConversations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <include layout="@layout/view_bottom_nav_mock" />

</LinearLayout>
