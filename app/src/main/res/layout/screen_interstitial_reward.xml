<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pastel_surface_white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Celebration Animation Mock -->
    <TextView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_button_magenta_round"
        android:gravity="center"
        android:text="🎉"
        android:textSize="60sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="UPLOAD SUCCESSFUL"
        android:textColor="@color/pastel_text_highlight"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Streak Update -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_photo_tile_round"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 5-Day Streak!"
            android:textColor="@color/pastel_accent_magenta"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Keep it up!"
            android:textColor="@color/pastel_text_primary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Points -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_photo_tile_round"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪙 +50 Points"
            android:textColor="@color/pastel_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Added to Weekly Score"
            android:textColor="@color/pastel_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Badges -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="🏅 New Badge Unlocked: Early Bird"
        android:textColor="@color/pastel_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/btnReturnToGallery"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_button_purple"
        android:gravity="center"
        android:text="BACK TO GALLERY"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>
