<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    android:background="@color/pastel_surface_white"
    android:elevation="8dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="18dp">

    <TextView
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="⌂"
        android:textColor="@color/pastel_text_primary"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/navGallery"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="▦"
        android:textColor="@color/pastel_text_primary"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/navLeaderboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="⌖"
        android:textColor="@color/pastel_text_primary"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/navUpload"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="+"
        android:textColor="@color/pastel_accent_magenta"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="◡"
        android:textColor="@color/pastel_text_primary"
        android:textSize="22sp" />
</LinearLayout>
