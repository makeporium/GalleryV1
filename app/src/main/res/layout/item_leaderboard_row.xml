<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <TextView
        android:id="@+id/tvLbRank"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:textColor="@color/pastel_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/ivLbAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_button_soft_purple_round"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tvLbName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textColor="@color/pastel_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvLbPoints"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/pastel_text_secondary"
        android:textSize="13sp" />

</LinearLayout>
