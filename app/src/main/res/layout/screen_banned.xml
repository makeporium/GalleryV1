<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pastel_surface_white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_button_magenta_round"
        android:gravity="center"
        android:text="🚫"
        android:textSize="60sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="ACCOUNT SUSPENDED"
        android:textColor="@color/pastel_accent_magenta"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="You have reached Strike 3.\n\nSnapShot is for real moments. Device ID has been flagged. No appeals."
        android:textColor="@color/pastel_text_primary"
        android:textSize="16sp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/btnBannedLogout"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_button_purple"
        android:gravity="center"
        android:text="LOG OUT"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>
