<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pastel_surface_white">

    <!-- Top Bar: back + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btnPostDetailBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="@color/pastel_text_primary" />
        <TextView
            android:id="@+id/tvPostDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Post"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/pastel_text_primary" />
        <TextView
            android:id="@+id/btnPostDetailDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑"
            android:textSize="20sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Scrollable content: image + interactions + comments -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- User info row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">
                <ImageView
                    android:id="@+id/ivPostDetailAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_soft_purple_round"
                    android:scaleType="centerCrop" />
                <TextView
                    android:id="@+id/tvPostDetailUsername"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/pastel_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Post image -->
            <ImageView
                android:id="@+id/ivPostDetailPhoto"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:scaleType="centerCrop"
                android:background="@color/pastel_surface_card" />

            <!-- Like + Comment row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="10dp">
                <TextView
                    android:id="@+id/btnPostDetailLike"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="♡ 0"
                    android:textSize="22sp"
                    android:textColor="@color/pastel_text_primary" />
                <TextView
                    android:id="@+id/tvPostDetailCommentsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="💬 0"
                    android:textSize="22sp"
                    android:textColor="@color/pastel_text_primary" />
            </LinearLayout>

            <!-- Tappable "N likes – see who liked" label -->
            <TextView
                android:id="@+id/tvPostDetailLikedBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="4dp"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/pastel_text_secondary"
                android:visibility="gone" />

            <!-- Caption -->
            <TextView
                android:id="@+id/tvPostDetailCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:textColor="@color/pastel_text_primary" />

            <!-- Comments label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp"
                android:text="Comments"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/pastel_text_primary" />

            <!-- Comments list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPostComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="8dp"
                android:minHeight="80dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Comment input always visible at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/etPostCommentInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_round"
            android:hint="Add a comment..."
            android:paddingHorizontal="10dp"
            android:textColor="@color/pastel_text_primary"
            android:textColorHint="@color/pastel_text_secondary" />
        <TextView
            android:id="@+id/btnPostCommentSend"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_button_purple"
            android:text="Send"
            android:textColor="@android:color/white" />
    </LinearLayout>

</LinearLayout>
