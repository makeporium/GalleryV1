<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E2D3EA"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="PREVIOUS CHALLENGES"
                android:textColor="#6C3D93"
                android:textSize="42sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="end"
                android:text="16/03/26"
                android:textColor="#2E2632"
                android:textSize="28sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/photo_city" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="end"
                android:text="15/03/26"
                android:textColor="#2E2632"
                android:textSize="28sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/photo_sunset" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="end"
                android:text="14/03/26"
                android:textColor="#2E2632"
                android:textSize="28sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/photo_waterfall" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="end"
                android:text="13/03/26"
                android:textColor="#2E2632"
                android:textSize="28sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/photo_mountain" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/view_bottom_nav_mock" />
</LinearLayout>
